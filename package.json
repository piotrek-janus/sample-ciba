{
  "name": "sample-ciba",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end SecureAuth/Cloudentity CIBA sample: consumption device + simulated authentication service",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "tunnel": "cloudflared tunnel --url http://localhost:${PORT:-3000}"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
