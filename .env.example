# ─── SecureAuth / Cloudentity tenant ───────────────────────────────────────────
# The OIDC issuer URL of your workspace. The sample discovers the
# backchannel_authentication_endpoint and token_endpoint from
# {ISSUER_URL}/.well-known/openid-configuration — you do NOT hardcode those.
# Example: https://<tenant>.<region>.authz.cloudentity.io/<tenant>/<workspace>
ISSUER_URL=

# ─── Consumption-device (CIBA client) credentials ──────────────────────────────
# A CONFIDENTIAL client with grant type urn:openid:params:grant-type:ciba allowed
# and a CIBA token delivery mode (poll or ping) configured.
CLIENT_ID=
CLIENT_SECRET=

# Token endpoint auth method for this client: client_secret_basic | client_secret_post
# Must match how the client is registered (check the client's "Token endpoint
# authentication method" in SecureAuth).
CLIENT_AUTH_METHOD=client_secret_basic

# Default scope requested by the consumption device.
SCOPE=openid profile

# Token delivery mode: poll | ping
TOKEN_DELIVERY_MODE=poll

# ─── System API (authentication service → SecureAuth decision callback) ─────────
# The authentication service reports the user's approve/reject decision via the
# SecureAuth System API (logins tag): getScopeGrantRequest / acceptScopeGrantRequest
# / rejectScopeGrantRequest.
#
# Base URL for the System API (no trailing slash). Verify the exact value for your
# tenant; commonly the system workspace under your tenant host, e.g.:
#   https://<tenant>.<region>.authz.cloudentity.io/api/system/<tenant>
SYSTEM_API_BASE_URL=

# Path templates for the scope-grants operations. {login} is replaced with the
# login_id received in the startAuthentication notification. Full URL looks like:
#   {SYSTEM_API_BASE_URL}/scope-grants/{login}/accept
SYSTEM_API_GET_PATH=/scope-grants/{login}
SYSTEM_API_ACCEPT_PATH=/scope-grants/{login}/accept
SYSTEM_API_REJECT_PATH=/scope-grants/{login}/reject

# System API authentication via client_credentials (an admin/system client).
SYSTEM_API_TOKEN_URL=
SYSTEM_API_CLIENT_ID=
SYSTEM_API_CLIENT_SECRET=
# client_secret_basic | client_secret_post (match the system client's registration)
SYSTEM_API_CLIENT_AUTH_METHOD=client_secret_basic
SYSTEM_API_SCOPE=

# ─── Server / reachability ─────────────────────────────────────────────────────
# Basic auth credentials SecureAuth uses when calling this authentication service.
# Set these to match the Credentials configured on the CIBA tab in SecureAuth.
# Leave unset to disable the inbound Basic-auth check (accept all).
AUTH_SERVICE_BASIC_USER=
AUTH_SERVICE_BASIC_PASSWORD=

PORT=3000
# Public base URL SecureAuth uses to reach this app (e.g. your cloudflared URL).
# Register PUBLIC_BASE_URL itself as the External CIBA Authentication Service URL
# in SecureAuth — it appends /user/verify and /authentication/start. In ping mode,
# register {PUBLIC_BASE_URL}/api/cd/ping as the client notification endpoint.
PUBLIC_BASE_URL=http://localhost:3000

# Poll safety cap (seconds) in addition to the request's expires_in.
POLL_MAX_SECONDS=120
